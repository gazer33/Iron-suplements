---
import Icon from "../icon/icons.astro";
import HamburgerMenu from "../../assets/icons/hamburger-icon.svg?raw";
---

<nav id="site-nav" class="fixed z-50 w-full bg-black text-white">
  <div class="flex items-center justify-between px-6 py-5 md:px-10">
    <h2 class="text-display-9 font-mono font-mid text-yellow-300">
      logo
    </h2>

    <ul class="hidden items-center gap-10 text-display-6 font-medium xl:flex">
      <li><a href="/" class="cursor-pointer transition-all hover:opacity-70">Home</a></li>
      <li><a href="/programs" class="cursor-pointer transition-all hover:opacity-70">Products</a></li>
      <li><a href="/about" class="cursor-pointer transition-all hover:opacity-70">About</a></li>
      <li><a href="/contact" class="cursor-pointer transition-all hover:opacity-70">Contact</a></li>
    </ul>

    <div class="xl:hidden">
      <button
        id="hamburger-button"
        aria-controls="mobile-menu"
        aria-expanded="false"
        aria-label="Abrir menú"
        class="z-20 rounded-full border border-zinc-800 p-2 transition-colors hover:border-zinc-600 focus:outline-none"
      >
        <Icon icon={HamburgerMenu} iconClass="h-6 w-6 text-white transition-all hover:opacity-55" />
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="pointer-events-none absolute left-0 top-full w-full border-t border-zinc-800 bg-black/95 px-6 pb-8 pt-6 opacity-0 backdrop-blur-md transition-all duration-300 ease-out xl:hidden"
  >
    <ul class="flex flex-col items-center gap-6 text-center text-display-6 font-medium text-white">
      <li>
        <a href="/" data-mobile-menu-close class="block py-1 transition-opacity hover:opacity-70">Home</a>
      </li>

      <li class="w-full max-w-xs">
        <button
          id="mobile-products-trigger"
          type="button"
          aria-controls="mobile-products-submenu"
          aria-expanded="false"
          class="flex w-full items-center justify-center gap-3 py-1 text-center transition-opacity hover:opacity-70"
        >
          <span>Products</span>
          <svg
            id="mobile-products-arrow"
            class="h-4 w-4 flex-shrink-0 transition-transform duration-300"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.25" d="M19 9l-7 7-7-7" />
          </svg>
        </button>

        <div
          id="mobile-products-submenu"
          class="grid h-0 grid-cols-1 overflow-hidden opacity-0"
        >
          <div class="flex flex-col items-center gap-4 rounded-2xl border border-zinc-800 bg-zinc-950/80 px-6 py-5 text-display-5 text-zinc-200">
            <a href="/programs" data-mobile-menu-close class="transition-opacity hover:opacity-70">All Products</a>
            <a href="/producto/protein" data-mobile-menu-close class="transition-opacity hover:opacity-70">Protein</a>
            <a href="/producto/creatine" data-mobile-menu-close class="transition-opacity hover:opacity-70">Creatine</a>
            <a href="/producto/pre-workout" data-mobile-menu-close class="transition-opacity hover:opacity-70">Pre-Workout</a>
            <a href="/producto/bcaa" data-mobile-menu-close class="transition-opacity hover:opacity-70">BCAA</a>
          </div>
        </div>
      </li>

      <li>
        <a href="/about" data-mobile-menu-close class="block py-1 transition-opacity hover:opacity-70">About Us</a>
      </li>
      <li>
        <a href="/trainers" data-mobile-menu-close class="block py-1 transition-opacity hover:opacity-70">Experts</a>
      </li>
      <li>
        <a href="/contact" data-mobile-menu-close class="block py-1 transition-opacity hover:opacity-70">Contact</a>
      </li>
    </ul>
  </div>
</nav>

<script>
  import { gsap } from 'gsap';

  const siteNav = document.getElementById('site-nav');
  const hamburgerButton = document.getElementById('hamburger-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const productsTrigger = document.getElementById('mobile-products-trigger');
  const productsSubmenu = document.getElementById('mobile-products-submenu');
  const productsArrow = document.getElementById('mobile-products-arrow');
  const mobileMenuLinks = document.querySelectorAll('[data-mobile-menu-close]');

  if (siteNav && hamburgerButton && mobileMenu && productsTrigger && productsSubmenu && productsArrow) {
    const productsInner = productsSubmenu.firstElementChild;

    if (!(productsInner instanceof HTMLElement)) {
      throw new Error('Mobile products submenu content is missing.');
    }

    gsap.set(productsSubmenu, {
      height: 0,
      opacity: 0,
      overflow: 'hidden',
    });
    gsap.set(productsInner, {
      marginTop: 0,
    });
    gsap.set(productsArrow, {
      rotate: 0,
      transformOrigin: '50% 50%',
    });

    const closeProducts = () => {
      productsTrigger.setAttribute('aria-expanded', 'false');
      gsap.killTweensOf([productsSubmenu, productsInner, productsArrow]);
      gsap.to(productsArrow, {
        rotate: 0,
        duration: 0.35,
        ease: 'power2.out',
      });
      gsap.to(productsInner, {
        marginTop: 0,
        duration: 0.35,
        ease: 'power2.out',
      });
      gsap.to(productsSubmenu, {
        height: 0,
        opacity: 0,
        duration: 0.35,
        ease: 'power2.inOut',
      });
    };

    const openProducts = () => {
      productsTrigger.setAttribute('aria-expanded', 'true');
      gsap.killTweensOf([productsSubmenu, productsInner, productsArrow]);
      gsap.to(productsArrow, {
        rotate: 180,
        duration: 0.35,
        ease: 'power2.out',
      });
      gsap.to(productsSubmenu, {
        height: productsInner.offsetHeight,
        opacity: 1,
        duration: 0.35,
        ease: 'power2.inOut',
      });
      gsap.to(productsInner, {
        marginTop: 12,
        duration: 0.35,
        ease: 'power2.out',
      });
    };

    const closeMenu = () => {
      mobileMenu.classList.remove('translate-y-0', 'opacity-100', 'pointer-events-auto');
      mobileMenu.classList.add('-translate-y-4', 'opacity-0', 'pointer-events-none');
      hamburgerButton.setAttribute('aria-expanded', 'false');
      closeProducts();
    };

    const openMenu = () => {
      mobileMenu.classList.remove('-translate-y-4', 'opacity-0', 'pointer-events-none');
      mobileMenu.classList.add('translate-y-0', 'opacity-100', 'pointer-events-auto');
      hamburgerButton.setAttribute('aria-expanded', 'true');
    };

    closeMenu();

    hamburgerButton.addEventListener('click', () => {
      const isExpanded = hamburgerButton.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    productsTrigger.addEventListener('click', () => {
      const isExpanded = productsTrigger.getAttribute('aria-expanded') === 'true';
      if (isExpanded) {
        closeProducts();
      } else {
        openProducts();
      }
    });

    mobileMenuLinks.forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    document.addEventListener('click', (event) => {
      if (!(event.target instanceof Node)) return;
      if (!siteNav.contains(event.target)) {
        closeMenu();
      }
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth >= 1280) {
        closeMenu();
      } else if (productsTrigger.getAttribute('aria-expanded') === 'true') {
        gsap.set(productsSubmenu, {
          height: productsInner.offsetHeight,
        });
      }
    });
  }
</script>
