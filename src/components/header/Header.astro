---
import Icon from "../icon/icons.astro"
import HamburgerMenu from "../../assets/icons/hamburger-icon.svg?raw"

const currentPath = Astro.url.pathname;

const navItems = [
  { href: "/", label: "Inicio" },
  {
    href: "/programs",
    label: "Productos",
    dropdown: [
      { href: "/programs", label: "Todos", icon: "🏋️" },
      { href: "/producto/creatine", label: "Creatina", icon: "💪" },
      { href: "/producto/protein", label: "Proteína", icon: "🥛" },
      { href: "/producto/pre-workout", label: "Pre-Entreno", icon: "⚡" },
      { href: "/producto/bcaa", label: "BCAA", icon: "🔬" }
    ]
  },
  { href: "/about", label: "Nosotros" },
  { href: "/trainers", label: "Expertos" },
  { href: "/contact", label: "Contacto" }
];

// Helper function to check if a nav item is active
// Handles both exact matches and nested routes (e.g., /programs/item highlights "Productos")
const isActive = (itemHref: string, currentPath: string): boolean => {
  if (itemHref === '/') {
    // Home is only active on exact match
    return currentPath === '/';
  }
  // For other routes, check if current path starts with the item href
  return currentPath === itemHref || currentPath.startsWith(itemHref + '/');
};
---

<nav class="bg-black text-white fixed w-full z-50 top-0" id="main-nav">
  <div class="flex justify-between px-4 md:px-10 py-4 md:py-5 items-center max-w-[1920px] mx-auto">
    <a href="/" class="text-display-9 font-mono text-yellow-300 font-mid hover:opacity-80 transition-opacity duration-300">
      IRON SUPPLEMENTS
    </a>

    <ul class="hidden gap-6 xl:gap-10 text-display-6 font-medium xl:flex">
      {navItems.map(item => {
        const active = isActive(item.href, currentPath);
        const hasDropdown = 'dropdown' in item && item.dropdown;

        return (
          <li class="relative dropdown-container">
            {hasDropdown ? (
              <button
                class={`
                  relative py-1 px-2 rounded-sm flex items-center gap-1
                  transition-all duration-300 ease-out
                  hover:text-yellow-300
                  ${active ? 'text-yellow-300' : 'text-white'}
                  ${active ? 'after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-yellow-300 after:rounded-full' : ''}
                `}
                aria-haspopup="true"
                aria-expanded="false"
                data-dropdown-toggle
              >
                {item.label}
                <svg class="w-4 h-4 dropdown-arrow transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                </svg>
              </button>
            ) : (
              <a
                href={item.href}
                class={`
                  relative py-1 px-2 rounded-sm
                  transition-all duration-300 ease-out
                  hover:text-yellow-300
                  ${active ? 'text-yellow-300' : 'text-white'}
                  ${active ? 'after:absolute after:bottom-0 after:left-0 after:right-0 after:h-0.5 after:bg-yellow-300 after:rounded-full' : ''}
                `}
                aria-current={active ? 'page' : undefined}
              >
                {item.label}
              </a>
            )}

            {hasDropdown && (
              <div
                class="dropdown-menu absolute top-full left-0 mt-2 w-56 bg-zinc-900 border border-zinc-800 rounded-lg shadow-2xl opacity-0 invisible translate-y-2 transition-all duration-200 ease-out z-50"
                role="menu"
              >
                <div class="py-2">
                  {item.dropdown.map((dropItem: any) => {
                    const dropActive = currentPath === dropItem.href || currentPath.startsWith(dropItem.href + '/');
                    return (
                      <a
                        href={dropItem.href}
                        class={`
                          flex items-center gap-3 px-4 py-3
                          transition-all duration-200
                          hover:bg-zinc-800 hover:text-yellow-400
                          ${dropActive ? 'bg-zinc-800/50 text-yellow-400' : 'text-gray-300'}
                        `}
                        role="menuitem"
                      >
                        <span class="text-2xl">{dropItem.icon}</span>
                        <span class="font-medium">{dropItem.label}</span>
                      </a>
                    );
                  })}
                </div>
              </div>
            )}
          </li>
        );
      })}
    </ul>

    <div class="xl:hidden">
      <button
        id="hamburger-button"
        aria-label="Menú de navegación"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="focus:outline-none focus:ring-2 focus:ring-yellow-300 rounded z-20 p-2 transition-all duration-200"
      >
        <Icon icon={HamburgerMenu} iconClass="hover:opacity-55 transition-opacity duration-300 w-6 h-6 text-white" />
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div
    id="mobile-menu"
    role="dialog"
    aria-modal="true"
    aria-label="Menú de navegación móvil"
    class="
      xl:hidden fixed top-0 left-0 w-full h-screen bg-black z-40
      opacity-0 -translate-x-full pointer-events-none
      transition-all duration-300 ease-in-out overflow-y-auto
    "
  >
    <div class="flex flex-col items-center justify-center min-h-full gap-8 py-20">
      <ul class="flex flex-col items-center gap-6 text-display-6 md:text-display-8 font-medium w-full px-4">
        {navItems.map(item => {
          const active = isActive(item.href, currentPath);
          const hasDropdown = 'dropdown' in item && item.dropdown;

          return (
            <li class="w-full max-w-xs">
              {hasDropdown ? (
                <div class="mobile-dropdown-container w-full">
                  <button
                    class={`
                      w-full py-2 px-4 rounded-md flex items-center justify-between
                      transition-all duration-300 ease-out
                      hover:text-yellow-300 hover:bg-yellow-400/10
                      ${active ? 'text-yellow-300 bg-yellow-400/10' : 'text-white'}
                    `}
                    data-mobile-dropdown-toggle
                    aria-expanded="false"
                  >
                    <span>{item.label}</span>
                    <svg class="w-5 h-5 mobile-dropdown-arrow transition-transform duration-200" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                  </button>

                  <div class="mobile-dropdown-content max-h-0 overflow-hidden transition-all duration-300 ease-in-out">
                    <div class="py-2 pl-4">
                      {item.dropdown.map((dropItem: any) => {
                        const dropActive = currentPath === dropItem.href || currentPath.startsWith(dropItem.href + '/');
                        return (
                          <a
                            href={dropItem.href}
                            class={`
                              flex items-center gap-3 py-2 px-3 rounded-md
                              transition-all duration-200
                              hover:bg-zinc-800 hover:text-yellow-400
                              ${dropActive ? 'bg-zinc-800/50 text-yellow-400' : 'text-gray-300'}
                            `}
                          >
                            <span class="text-xl">{dropItem.icon}</span>
                            <span>{dropItem.label}</span>
                          </a>
                        );
                      })}
                    </div>
                  </div>
                </div>
              ) : (
                <a
                  href={item.href}
                  class={`
                    block w-full py-2 px-4 rounded-md text-center
                    transition-all duration-300 ease-out
                    hover:text-yellow-300 hover:bg-yellow-400/10
                    ${active ? 'text-yellow-300 bg-yellow-400/10' : 'text-white'}
                  `}
                  aria-current={active ? 'page' : undefined}
                >
                  {item.label}
                </a>
              )}
            </li>
          );
        })}
      </ul>
    </div>
  </div>
</nav>

<script>
  const hamburgerButton = document.getElementById('hamburger-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const body = document.body;

  // Desktop dropdown functionality
  const dropdownContainers = document.querySelectorAll('.dropdown-container');

  dropdownContainers.forEach(container => {
    const toggle = container.querySelector('[data-dropdown-toggle]');
    const menu = container.querySelector('.dropdown-menu');
    const arrow = container.querySelector('.dropdown-arrow');

    if (!toggle || !menu) return;

    let isOpen = false;

    // Toggle dropdown on button click
    toggle.addEventListener('click', (e) => {
      e.stopPropagation();
      isOpen = !isOpen;

      if (isOpen) {
        menu.classList.remove('opacity-0', 'invisible', 'translate-y-2');
        menu.classList.add('opacity-100', 'visible', 'translate-y-0');
        arrow?.classList.add('rotate-180');
        toggle.setAttribute('aria-expanded', 'true');
      } else {
        menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
        menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        arrow?.classList.remove('rotate-180');
        toggle.setAttribute('aria-expanded', 'false');
      }
    });

    // Close dropdown when clicking outside
    document.addEventListener('click', (e) => {
      if (!container.contains(e.target as Node) && isOpen) {
        menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
        menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        arrow?.classList.remove('rotate-180');
        toggle.setAttribute('aria-expanded', 'false');
        isOpen = false;
      }
    });

    // Close on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) {
        menu.classList.add('opacity-0', 'invisible', 'translate-y-2');
        menu.classList.remove('opacity-100', 'visible', 'translate-y-0');
        arrow?.classList.remove('rotate-180');
        toggle.setAttribute('aria-expanded', 'false');
        isOpen = false;
      }
    });
  });

  // Mobile dropdown functionality
  const mobileDropdownToggles = document.querySelectorAll('[data-mobile-dropdown-toggle]');

  mobileDropdownToggles.forEach(toggle => {
    const container = toggle.closest('.mobile-dropdown-container');
    const content = container?.querySelector('.mobile-dropdown-content');
    const arrow = toggle.querySelector('.mobile-dropdown-arrow');

    if (!content) return;

    toggle.addEventListener('click', () => {
      const isExpanded = toggle.getAttribute('aria-expanded') === 'true';

      if (isExpanded) {
        // Close dropdown
        content.style.maxHeight = '0';
        arrow?.classList.remove('rotate-180');
        toggle.setAttribute('aria-expanded', 'false');
      } else {
        // Open dropdown
        content.style.maxHeight = content.scrollHeight + 'px';
        arrow?.classList.add('rotate-180');
        toggle.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // Hamburger menu functionality
  if (hamburgerButton && mobileMenu) {
    hamburgerButton.addEventListener('click', () => {
      const isExpanded = hamburgerButton.getAttribute('aria-expanded') === 'true';

      if (isExpanded) {
        // Close menu
        mobileMenu.classList.add('opacity-0', '-translate-x-full', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'translate-x-0', 'pointer-events-auto');
        hamburgerButton.setAttribute('aria-expanded', 'false');
        body.style.overflow = '';
      } else {
        // Open menu
        mobileMenu.classList.remove('opacity-0', '-translate-x-full', 'pointer-events-none');
        mobileMenu.classList.add('opacity-100', 'translate-x-0', 'pointer-events-auto');
        hamburgerButton.setAttribute('aria-expanded', 'true');
        body.style.overflow = 'hidden';
      }
    });

    // Close menu when clicking on a non-dropdown link
    const menuLinks = mobileMenu.querySelectorAll('a');
    menuLinks.forEach(link => {
      link.addEventListener('click', () => {
        mobileMenu.classList.add('opacity-0', '-translate-x-full', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'translate-x-0', 'pointer-events-auto');
        hamburgerButton.setAttribute('aria-expanded', 'false');
        body.style.overflow = '';
      });
    });

    // Close menu on escape key
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && hamburgerButton.getAttribute('aria-expanded') === 'true') {
        mobileMenu.classList.add('opacity-0', '-translate-x-full', 'pointer-events-none');
        mobileMenu.classList.remove('opacity-100', 'translate-x-0', 'pointer-events-auto');
        hamburgerButton.setAttribute('aria-expanded', 'false');
        body.style.overflow = '';
      }
    });
  }
</script>
