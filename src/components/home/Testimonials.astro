---
import { getCollection } from 'astro:content';

const testimonials = await getCollection('testimonials');
const sortedTestimonials = testimonials.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<section class="py-sections-xs bg-white" id="testimonials">
  <div class="max-w-container-treatments mx-auto px-4 md:px-10">
    <div class="text-center mb-12">
      <h2 class="md:text-display-11 text-display-mobile-10 font-oswald font-bold text-black mb-4">
        Lo que dicen nuestros clientes
      </h2>
      <p class="text-display-6 text-gray-600 max-w-2xl mx-auto">
        Miles de clientes satisfechos han transformado su rendimiento con nuestros productos
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8" id="testimonials-grid">
      {sortedTestimonials.map((testimonial, index) => (
        <div
          class="testimonial-card bg-gray-50 rounded-radius-lg p-6 md:p-8 hover:shadow-xl transition-all"
          data-index={index}
        >
          <div class="flex gap-1 mb-4">
            {Array.from({ length: testimonial.data.rating }).map(() => (
              <svg class="w-5 h-5 text-yellow-400 fill-current" viewBox="0 0 20 20">
                <path d="M10 15l-5.878 3.09 1.123-6.545L.489 6.91l6.572-.955L10 0l2.939 5.955 6.572.955-4.756 4.635 1.123 6.545z" />
              </svg>
            ))}
          </div>
          <p class="text-display-6 text-gray-700 mb-6 leading-relaxed">
            "{testimonial.data.content}"
          </p>
          <div class="border-t border-gray-200 pt-4">
            <p class="font-oswald font-semibold text-display-7 text-black">
              {testimonial.data.author}
            </p>
            {testimonial.data.role && (
              <p class="text-display-4 text-gray-500 mt-1">
                {testimonial.data.role}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
