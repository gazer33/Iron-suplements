<section class="py-sections-xs bg-black text-white relative overflow-hidden" id="cta">
  <div class="absolute inset-0 opacity-10">
    <div class="absolute top-0 left-0 w-96 h-96 bg-yellow-300 rounded-full blur-3xl"></div>
    <div class="absolute bottom-0 right-0 w-96 h-96 bg-yellow-300 rounded-full blur-3xl"></div>
  </div>

  <div class="max-w-4xl mx-auto px-4 md:px-10 text-center relative z-10">
    <h2 class="text-display-mobile-11 md:text-display-12 font-oswald font-bold mb-6 leading-106">
      ¿Listo para alcanzar tu máximo potencial?
    </h2>
    <p class="text-display-6 md:text-display-8 text-gray-300 mb-10 max-w-2xl mx-auto">
      Únete a miles de atletas que ya confían en Supplement Store para mejorar su rendimiento y alcanzar sus metas.
    </p>
    <div class="flex flex-col sm:flex-row gap-4 justify-center items-center">
      <a
        href="/programs"
        class="bg-yellow-400 text-black text-display-7 md:text-display-9 font-oswald font-mid px-8 py-4 rounded-radius-sm transition-all duration-300 ease-out hover:bg-yellow-300 hover:scale-105 w-full sm:w-auto text-center"
      >
        Ver Productos
      </a>
      <a
        href="/contact"
        class="border-2 border-yellow-400 text-yellow-400 text-display-7 md:text-display-9 font-oswald font-mid px-8 py-4 rounded-radius-sm transition-all duration-300 ease-out hover:bg-yellow-400 hover:text-black w-full sm:w-auto text-center"
      >
        Contactar Ahora
      </a>
    </div>
  </div>
</section>
