---
import { Image } from "astro:assets"
import ImageHero from "../../assets/images/iron-bg.png"
---

<section class="bg-black text-white xl:p-0 md:pb-[600px] pb-[200px] overflow-hidden rounded-b-radius-xl pt-20 md:pt-24 relative">
  <div class="xl:flex xl:flex-row justify-center items-center">
    <Image
      alt="Supplement Store - Suplementos Deportivos Premium"
      src={ImageHero}
      class="xl:max-h-[120vh] 2xl:max-h-[70vh] w-auto xl:opacity-100 opacity-40"
      loading="eager"
    />
    <div class="flex flex-col items-center xl:max-w-[50%] gap-6 md:gap-10 xl:mt-0 mt-[-400px] md:mt-[-800px] relative z-40 px-4">
      <h1 class="hero-title lg:text-[90px] lg:max-w-[50%] xl:max-w-[100%] text-display-mobile-12 md:text-display-10 leading-106 text-center font-oswald font-bold">
        ALIMENTA TU RENDIMIENTO
      </h1>
      <p class="text-display-6 md:text-display-8 text-gray-300 text-center max-w-2xl px-4">
        Suplementos deportivos premium para alcanzar tu máximo potencial. Calidad garantizada, resultados comprobados.
      </p>

      <!-- Improved CTA Buttons -->
      <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 w-full sm:w-auto px-4 max-w-xl">
        <!-- Primary CTA -->
        <a
          href="/programs"
          class="hero-button
            inline-flex items-center justify-center
            bg-yellow-400 text-black
            px-6 py-3 sm:px-7 sm:py-3.5
            rounded-lg
            font-oswald font-semibold text-base sm:text-lg
            whitespace-nowrap
            transition-all duration-300 ease-out
            hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
            focus:outline-none focus:ring-2 focus:ring-yellow-300 focus:ring-offset-2 focus:ring-offset-black
            text-center
            min-h-[48px] sm:min-h-[52px]"
        >
          Ver Productos
        </a>

        <!-- Secondary CTA -->
        <a
          href="/contact"
          class="hero-button
            inline-flex items-center justify-center
            border-2 border-yellow-400 text-yellow-400
            px-6 py-3 sm:px-7 sm:py-3.5
            rounded-lg
            font-oswald font-semibold text-base sm:text-lg
            whitespace-nowrap
            transition-all duration-300 ease-out
            hover:bg-yellow-400 hover:text-black hover:shadow-lg hover:scale-[1.02]
            focus:outline-none focus:ring-2 focus:ring-yellow-300 focus:ring-offset-2 focus:ring-offset-black
            text-center
            min-h-[48px] sm:min-h-[52px]"
        >
          Contáctanos
        </a>
      </div>
    </div>
  </div>
</section>
