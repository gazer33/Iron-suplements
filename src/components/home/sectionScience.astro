---
import { Image } from "astro:assets"
import Molecula from "../../assets/images/abc.png"
import Adn from "../../assets/images/adn.png"
import Abc from "../../assets/images/molecula.png"

const cards = [
  {
    id: 1,
    image: Abc,
    title: "Creatina Monohidratada",
    description: "Un suplemento probado que mejora el rendimiento y aumenta la fuerza muscular de forma segura.",
  },
  {
    id: 2,
    image: Adn,
    title: "Aminoácidos de Cadena Ramificada (BCAA)",
    description: "Favorecen la recuperación muscular y reducen el dolor después del ejercicio intenso.",
  },
  {
    id: 3,
    image: Molecula,
    title: "Vitaminas Esenciales",
    description: "Compuestos necesarios para la salud general y el bienestar óptimo del organismo.",
  },
]
---

<section class="bg-[#161818] py-sections-xs rounded-t-[32px]">
  <div class="flex flex-col justify-center items-center text-center gap-12 px-4 md:px-10">
    <!-- Header -->
    <div class="text-white flex flex-col justify-center items-center gap-5 max-w-3xl">
      <h2 class="text-display-mobile-11 md:text-display-12 font-oswald font-bold leading-106">
        LA CIENCIA DETRÁS DE TUS SUPLEMENTOS
      </h2>
      <p class="text-display-5 md:text-display-6 text-gray-300 leading-relaxed max-w-2xl">
        Exploramos la investigación y los mecanismos detrás de los ingredientes clave que encuentras en nuestros productos, para que tomes decisiones informadas sobre tu suplementación.
      </p>
    </div>

    <!-- Cards Container -->
    <div class="w-full max-w-container-treatments">
      <!-- Decorative Divider -->
      <div class="bg-yellow-400 w-full h-[2px] rounded-full mb-12"></div>

      <!-- Cards Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        {cards.map((card) => (
          <div
            key={card.id}
            class="science-card bg-yellow-400 rounded-radius-lg flex flex-col items-center p-8 hover:bg-yellow-300 transition-all duration-500 group h-full"
          >
            <!-- Card Header -->
            <h3 class="font-oswald text-display-8 md:text-display-9 font-bold uppercase leading-106 text-center mb-6 min-h-[4rem] flex items-center">
              {card.title}
            </h3>

            <!-- Image Container - Fixed Height -->
            <div class="w-full flex items-center justify-center mb-6 h-[200px]">
              <Image
                alt={card.title}
                src={card.image}
                class="max-w-[180px] max-h-[180px] object-contain transform group-hover:scale-110 transition-transform duration-500"
              />
            </div>

            <!-- Card Content - Flex Grow to Push Button Down -->
            <div class="flex flex-col gap-5 justify-between items-center flex-grow w-full">
              <p class="text-display-5 md:text-display-6 font-medium text-black leading-relaxed text-center">
                {card.description}
              </p>

              <!-- Button - Always at Bottom -->
              <a
                href="/programs"
                class="
                  inline-flex items-center justify-center
                  text-display-6 md:text-display-7 font-oswald font-semibold
                  border-2 border-black text-black
                  px-6 py-2.5
                  rounded-lg
                  transition-all duration-300 ease-out
                  hover:bg-black hover:text-yellow-400
                  focus:outline-none focus:ring-2 focus:ring-black focus:ring-offset-2 focus:ring-offset-yellow-400
                  whitespace-nowrap
                  min-h-[44px]
                  w-full sm:w-auto
                "
              >
                Descubre Más
              </a>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
