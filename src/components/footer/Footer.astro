---
import Icon from "../icon/icons.astro";
import locationIcon from "../../assets/icons/location-yellow.svg?raw";
import MailIcon from "../../assets/icons/mail-yellow.svg?raw";
import PhoneIcon from "../../assets/icons/phone-yellow.svg?raw";

const currentYear = new Date().getFullYear();

const quickLinks = [
  { href: "/", label: "Inicio" },
  { href: "/programs", label: "Productos" },
  { href: "/about", label: "Nosotros" },
  { href: "/trainers", label: "Expertos" }
];

const legalLinks = [
  
  { href: "/contact", label: "Contacto" }
];
---

<footer class="bg-black text-white">
  <div class="max-w-[1920px] mx-auto px-4 md:px-10 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 md:gap-12">
      <!-- Brand Section -->
      <div class="space-y-4">
        <h3 class="text-display-9 font-oswald font-bold text-yellow-300">
          IRON SUPPLEMENTS
        </h3>
        <p class="text-display-5 text-gray-300 leading-relaxed">
          Tu socio confiable en suplementación deportiva premium. Ayudándote a alcanzar tu máximo potencial.
        </p>
        <div class="flex gap-4 pt-2">
          <a
            href="#"
            aria-label="Síguenos en Facebook"
            class="w-10 h-10 rounded-full bg-yellow-300 hover:bg-yellow-400 flex items-center justify-center transition-all duration-300 ease-out hover:scale-110"
          >
            <span class="text-black font-bold">f</span>
          </a>
          <a
            href="#"
            aria-label="Síguenos en Instagram"
            class="w-10 h-10 rounded-full bg-yellow-300 hover:bg-yellow-400 flex items-center justify-center transition-all duration-300 ease-out hover:scale-110"
          >
            <span class="text-black font-bold">ig</span>
          </a>
          <a
            href="#"
            aria-label="Síguenos en WhatsApp"
            class="w-10 h-10 rounded-full bg-yellow-300 hover:bg-yellow-400 flex items-center justify-center transition-all duration-300 ease-out hover:scale-110"
          >
            <span class="text-black font-bold">wa</span>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="space-y-4">
        <h4 class="text-display-7 font-oswald font-semibold text-yellow-300">
          Enlaces Rápidos
        </h4>
        <ul class="space-y-2">
          {quickLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-display-5 text-gray-300 hover:text-yellow-300 transition-colors duration-300 ease-out"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- More Links -->
      <div class="space-y-4">
        <h4 class="text-display-7 font-oswald font-semibold text-yellow-300">
          Más Información
        </h4>
        <ul class="space-y-2">
          {legalLinks.map(link => (
            <li>
              <a
                href={link.href}
                class="text-display-5 text-gray-300 hover:text-yellow-300 transition-colors duration-300 ease-out"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact Info -->
      <div class="space-y-4">
        <h4 class="text-display-7 font-oswald font-semibold text-yellow-300">
          Contacto
        </h4>
        <ul class="space-y-3 text-display-5 text-gray-300">
          <li class="flex gap-2 items-start">
            <Icon icon={locationIcon} iconClass="w-5 h-5 flex-shrink-0 mt-1" />
            <span>Av. Mirasol, Jaral, Atizapán de Zaragoza</span>
          </li>
          <li class="flex gap-2 items-center">
            <Icon icon={PhoneIcon} iconClass="w-5 h-5 flex-shrink-0" />
            <a href="tel:+525543455565" class="hover:text-yellow-300 transition-colors duration-300 ease-out">
              +52 55 4345 5565
            </a>
          </li>
          <li class="flex gap-2 items-center">
            <Icon icon={MailIcon} iconClass="w-5 h-5 flex-shrink-0" />
            <a href="mailto:ironSupplements@contact.com" class="hover:text-yellow-300 transition-colors duration-300 ease-out break-all">
              ironSupplements@contact.com
            </a>
          </li>
        </ul>
        <div class="pt-2">
          <p class="text-display-4 text-gray-400 font-oswald">
            Horario: Martes a Domingo
          </p>
          <p class="text-display-4 text-gray-400 font-oswald">
            9:00 AM - 8:00 PM
          </p>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="mt-12 pt-8 border-t border-gray-700">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4">
        <p class="text-display-4 text-gray-400 text-center md:text-left">
          © {currentYear} Iron Supplements. Todos los derechos reservados.
        </p>
        <p class="text-display-4 text-gray-400 text-center md:text-right">
          Suplementos de calidad premium para tu rendimiento óptimo
        </p>
      </div>
    </div>
  </div>
</footer>
