---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import '../styles/global.css';
import '../styles/fonts.css';

const values = [
  {
    icon: "🎯",
    title: "Calidad Premium",
    description: "Solo trabajamos con las mejores marcas y productos 100% originales certificados"
  },
  {
    icon: "🔬",
    title: "Respaldo Científico",
    description: "Todos nuestros productos están respaldados por investigación científica comprobada"
  },
  {
    icon: "👥",
    title: "Asesoría Experta",
    description: "Contamos con especialistas certificados para guiarte en tu proceso"
  },
  {
    icon: "💪",
    title: "Resultados Comprobados",
    description: "Miles de clientes satisfechos respaldan la efectividad de nuestros productos"
  }
];
---

<BaseLayout
  title="Nosotros - Iron Supplements"
  description="Conoce la historia de Iron Supplements. Más de 8 años ayudando a atletas a alcanzar su máximo potencial con suplementos de calidad premium."
>
  <Header />

  <main class="pt-20 md:pt-24">
    <!-- Hero Section -->
    <section class="bg-black text-white py-20 md:py-32">
      <div class="max-w-container-treatments mx-auto px-4 md:px-10">
        <div class="max-w-4xl mx-auto text-center">
          <h1 class="text-display-mobile-11 md:text-display-12 font-oswald font-bold mb-6 leading-106 animate-section">
            Nuestra Historia
          </h1>
          <p class="text-display-6 md:text-display-8 text-gray-300">
            Más de 8 años de pasión por el fitness y compromiso con la excelencia
          </p>
        </div>
      </div>
    </section>

    <!-- Story Section -->
    <section class="py-sections-xs bg-white animate-section">
      <div class="max-w-4xl mx-auto px-4 md:px-10">
        <div class="prose prose-lg max-w-none">
          <p class="text-display-6 md:text-display-8 text-gray-700 mb-6 leading-relaxed">
            Iron Supplements nació de una pasión: ayudar a las personas a alcanzar su máximo potencial físico. Comenzamos como una pequeña tienda local en Atizapán de Zaragoza, con la misión de proporcionar suplementos deportivos de la más alta calidad.
          </p>
          <p class="text-display-6 md:text-display-8 text-gray-700 mb-6 leading-relaxed">
            Lo que nos distingue no es solo la calidad de nuestros productos, sino nuestro compromiso con cada cliente. Entendemos que cada persona tiene objetivos únicos, y por eso ofrecemos asesoría personalizada basada en ciencia y experiencia comprobada.
          </p>
          <p class="text-display-6 md:text-display-8 text-gray-700 leading-relaxed">
            Hoy, después de más de 8 años, seguimos siendo fieles a esa misión original: proporcionar suplementos premium, asesoría experta y un servicio excepcional a cada uno de nuestros clientes.
          </p>
        </div>
      </div>
    </section>

    <!-- Values Section -->
    <section class="py-sections-xs bg-gray-50 animate-section">
      <div class="max-w-container-treatments mx-auto px-4 md:px-10">
        <div class="text-center mb-16">
          <h2 class="text-display-10 md:text-display-11 font-oswald font-bold text-black mb-4">
            Nuestros Valores
          </h2>
          <p class="text-display-6 text-gray-600 max-w-2xl mx-auto">
            Los principios que guían cada decisión que tomamos
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 animate-cards">
          {values.map((value, index) => (
            <div class="card-item bg-white p-8 rounded-radius-lg hover:shadow-xl transition-all" data-index={index}>
              <div class="text-5xl mb-4">{value.icon}</div>
              <h3 class="text-display-8 md:text-display-9 font-oswald font-bold text-black mb-3">
                {value.title}
              </h3>
              <p class="text-display-6 text-gray-600 leading-relaxed">
                {value.description}
              </p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="py-sections-xs bg-yellow-400 animate-section">
      <div class="max-w-4xl mx-auto px-4 md:px-10 text-center">
        <h2 class="text-display-10 md:text-display-11 font-oswald font-bold text-black mb-6">
          Nuestra Misión
        </h2>
        <p class="text-display-7 md:text-display-9 font-oswald text-gray-800 leading-relaxed">
          "Proporcionar suplementos deportivos de calidad premium y asesoría experta para ayudar a cada persona a alcanzar su máximo potencial físico y superar sus límites."
        </p>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-black text-white">
      <div class="max-w-4xl mx-auto px-4 md:px-10 text-center">
        <h2 class="text-display-10 md:text-display-11 font-oswald font-bold mb-6">
          ¿Listo para comenzar tu transformación?
        </h2>
        <p class="text-display-6 md:text-display-8 text-gray-300 mb-8">
          Únete a nuestra comunidad y descubre cómo podemos ayudarte a alcanzar tus metas
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="/programs"
            class="bg-yellow-400 text-black text-display-7 md:text-display-9 font-oswald font-mid px-8 py-4 rounded-radius-sm transition-all hover:bg-yellow-300"
          >
            Ver Productos
          </a>
          <a
            href="/contact"
            class="border-2 border-yellow-400 text-yellow-400 text-display-7 md:text-display-9 font-oswald font-mid px-8 py-4 rounded-radius-sm transition-all hover:bg-yellow-400 hover:text-black"
          >
            Contactar
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    import { initScrollAnimations } from '../utils/animations';
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initScrollAnimations);
    } else {
      initScrollAnimations();
    }
  </script>
</BaseLayout>
