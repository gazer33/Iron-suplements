---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import { Image } from "astro:assets";
import ExpertsHero from "../assets/images/expertos-hero.png"; 
import '../styles/global.css';
import '../styles/fonts.css';

const trainers = await getCollection('trainers');
const sortedTrainers = trainers.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout
  title="Nuestros Expertos - Iron Supplements"
  description="Conoce a nuestro equipo de expertos certificados en nutrición deportiva y suplementación. Asesoría personalizada para alcanzar tus objetivos."
>
  <Header />

  <main class="bg-black">
    <!-- Hero Section - Interactive with 16:9 Image -->
    <section class="bg-black text-white py-16 md:py-24 lg:py-32 overflow-hidden pt-20 md:pt-24">
      <div class="max-w-[1400px] mx-auto px-4 md:px-10">
        <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

          <!-- Left Column: Content & Stats -->
          <div class="hero-content opacity-0 space-y-8">
            <!-- Title & Description -->
            <div>
              <div class="inline-block mb-4">
                <span class="bg-yellow-400/10 text-yellow-400 px-4 py-2 rounded-full text-display-5 md:text-display-6 font-oswald uppercase tracking-wider border border-yellow-400/30">
                  Nuestro Equipo
                </span>
              </div>
              <h1 class="hero-title text-display-11 md:text-display-12 lg:text-[80px] font-oswald font-bold mb-6 leading-106">
                EXPERTOS EN<br />
                <span class="text-yellow-400">NUTRICIÓN</span><br />
                DEPORTIVA
              </h1>
              <p class="text-display-6 md:text-display-8 text-gray-300 leading-relaxed max-w-xl">
                Profesionales certificados con años de experiencia dedicados a ayudarte a alcanzar tus objetivos mediante asesoría personalizada y basada en ciencia
              </p>
            </div>

            <!-- CTA Buttons -->
            <div class="flex flex-col sm:flex-row gap-4">
              <a
                href="#expertos"
                class="hero-button inline-flex items-center justify-center
                  bg-yellow-400 text-black
                  px-8 py-4 rounded-lg
                  font-oswald font-semibold text-display-6 md:text-display-7
                  transition-all duration-300 ease-out
                  hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
                  focus:outline-none focus:ring-2 focus:ring-yellow-300"
              >
                Conocer al Equipo
              </a>
              <a
                href="/contact"
                class="hero-button inline-flex items-center justify-center
                  border-2 border-yellow-400 text-yellow-400
                  px-8 py-4 rounded-lg
                  font-oswald font-semibold text-display-6 md:text-display-7
                  transition-all duration-300 ease-out
                  hover:bg-yellow-400 hover:text-black hover:shadow-lg hover:scale-[1.02]
                  focus:outline-none focus:ring-2 focus:ring-yellow-300"
              >
                Agendar Consulta
              </a>
            </div>

            <!-- Stats Grid with Animation Counters -->
            <div class="grid grid-cols-3 gap-6 pt-8 border-t border-zinc-800">
              <div class="stat-item">
                <p class="text-display-10 md:text-display-11 font-oswald font-bold text-yellow-400">
                  <span class="counter" data-target="15">0</span>+
                </p>
                <p class="text-display-4 md:text-display-5 text-gray-400 uppercase tracking-wide">
                  Años de<br />Experiencia
                </p>
              </div>
              <div class="stat-item">
                <p class="text-display-10 md:text-display-11 font-oswald font-bold text-yellow-400">
                  <span class="counter" data-target="500">0</span>+
                </p>
                <p class="text-display-4 md:text-display-5 text-gray-400 uppercase tracking-wide">
                  Clientes<br />Asesorados
                </p>
              </div>
              <div class="stat-item">
                <p class="text-display-10 md:text-display-11 font-oswald font-bold text-yellow-400">
                  <span class="counter" data-target="100">0</span>%
                </p>
                <p class="text-display-4 md:text-display-5 text-gray-400 uppercase tracking-wide">
                  Basado en<br />Ciencia
                </p>
              </div>
            </div>
          </div>

          <!-- Right Column: 16:9 Hero Image -->
          <div class="hero-image opacity-0 relative">
            <div class="relative overflow-hidden rounded-2xl shadow-2xl aspect-video bg-zinc-900">
              <!-- Placeholder for now - uncomment Image when you add experts-hero.png -->
              
              <!--
              <div class="absolute inset-0 flex items-center justify-center bg-gradient-to-br from-yellow-400/20 to-zinc-900">
                <div class="text-center p-8">
                  <svg class="w-24 h-24 mx-auto mb-4 text-yellow-400/50" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                  </svg>
                  <p class="text-gray-500 text-display-5">
                    Add experts-hero.png to<br />/src/assets/images/
                  </p>
                </div>
              </div>
             -->
              <Image
                src={ExpertsHero}
                alt="Iron Supplements Expert Team"
                class="w-full h-full object-cover"
                loading="eager"
              />
              
             
              <!-- Floating Badge -->
              <div class="absolute top-6 right-6 bg-black/80 backdrop-blur-sm rounded-lg p-4 border border-yellow-400/30 floating-badge">
                <div class="flex items-center gap-3">
                  
                  <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center">
                    
                    <svg class="w-6 h-6 text-black" fill="currentColor" viewBox="0 0 20 20">
                      <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
                    </svg>
                  </div>
                  <div>
                    <p class="text-white font-oswald font-bold text-display-6">Certificados</p>
                    <p class="text-gray-400 text-display-4">Internacionalmente</p>
                  </div>
                </div>
              </div>
            </div>

            <!-- Decorative Element -->
            <div class="absolute -bottom-6 -right-6 w-32 h-32 bg-yellow-400/10 rounded-full blur-3xl"></div>
            <div class="absolute -top-6 -left-6 w-40 h-40 bg-yellow-400/5 rounded-full blur-3xl"></div>
          </div>
        </div>
      </div>
    </section>

    <!-- Trainers Grid -->
    <section id="expertos" class="py-sections-xs bg-neutral-900">
      <div class="max-w-container-treatments mx-auto px-4 md:px-10">
        <!-- Section Header -->
        <div class="text-center mb-12 md:mb-16 animate-section">
          <h2 class="text-display-10 md:text-display-11 lg:text-[64px] font-oswald font-bold text-white mb-4">
            Conoce a Nuestro Equipo
          </h2>
          <p class="text-display-6 md:text-display-7 text-gray-400 max-w-2xl mx-auto">
            Expertos certificados comprometidos con tu éxito
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 animate-cards">
          {sortedTrainers.map((trainer, index) => (
            <div class="card-item bg-zinc-800/50 backdrop-blur-sm rounded-radius-lg overflow-hidden border border-zinc-700 hover:border-yellow-400/50 transition-all duration-300 group" data-index={index}>
              <div class="bg-yellow-400 h-64 flex items-center justify-center relative overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-yellow-300 to-yellow-500 opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
                <div class="w-48 h-48 bg-zinc-900/20 rounded-full flex items-center justify-center relative z-10 transform group-hover:scale-110 transition-transform duration-500">
                  <span class="text-6xl">👤</span>
                </div>
              </div>
              <div class="p-6">
                <h2 class="text-display-9 md:text-display-10 font-oswald font-bold text-white mb-2 group-hover:text-yellow-400 transition-colors">
                  {trainer.data.name}
                </h2>
                <p class="text-display-6 text-yellow-400 font-semibold mb-4">
                  {trainer.data.title}
                </p>
                <p class="text-display-5 text-gray-300 mb-4 leading-relaxed">
                  {trainer.data.bio}
                </p>

                <div class="mb-4">
                  <h3 class="font-oswald font-semibold text-display-6 text-white mb-2">
                    Especialidades:
                  </h3>
                  <div class="flex flex-wrap gap-2">
                    {trainer.data.specialties.map((specialty: string) => (
                      <span class="bg-yellow-400/10 text-yellow-400 text-display-4 px-3 py-1 rounded-full border border-yellow-400/30">
                        {specialty}
                      </span>
                    ))}
                  </div>
                </div>

                {trainer.data.certifications && (
                  <div class="mb-4">
                    <h3 class="font-oswald font-semibold text-display-6 text-white mb-2">
                      Certificaciones:
                    </h3>
                    <ul class="space-y-1">
                      {trainer.data.certifications.map((cert: string) => (
                        <li class="text-display-4 text-gray-400 flex items-start gap-2">
                          <svg class="w-4 h-4 text-yellow-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                          </svg>
                          <span>{cert}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}

                <div class="pt-4 border-t border-zinc-700">
                  <p class="text-display-5 text-gray-400">
                    <span class="font-semibold text-white">Experiencia:</span> {trainer.data.experience}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Why Choose Us Section -->
    <section class="py-20 bg-zinc-900 border-y border-zinc-800 animate-section">
      <div class="max-w-4xl mx-auto px-4 md:px-10">
        <div class="text-center mb-12">
          <h2 class="text-display-10 md:text-display-11 font-oswald font-bold text-white mb-4">
            ¿Por qué elegirnos?
          </h2>
          <p class="text-display-6 text-gray-400">
            La diferencia que marca tu éxito
          </p>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          <div class="flex gap-4 p-6 rounded-lg bg-zinc-800/30 border border-zinc-800 hover:border-yellow-400/30 transition-all duration-300">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center">
                <span class="text-2xl">🎓</span>
              </div>
            </div>
            <div>
              <h3 class="font-oswald font-bold text-display-7 text-white mb-2">
                Profesionales Certificados
              </h3>
              <p class="text-display-5 text-gray-400">
                Todos nuestros expertos cuentan con certificaciones reconocidas internacionalmente
              </p>
            </div>
          </div>
          <div class="flex gap-4 p-6 rounded-lg bg-zinc-800/30 border border-zinc-800 hover:border-yellow-400/30 transition-all duration-300">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center">
                <span class="text-2xl">🔬</span>
              </div>
            </div>
            <div>
              <h3 class="font-oswald font-bold text-display-7 text-white mb-2">
                Enfoque Científico
              </h3>
              <p class="text-display-5 text-gray-400">
                Recomendaciones basadas en evidencia científica y resultados comprobados
              </p>
            </div>
          </div>
          <div class="flex gap-4 p-6 rounded-lg bg-zinc-800/30 border border-zinc-800 hover:border-yellow-400/30 transition-all duration-300">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center">
                <span class="text-2xl">👥</span>
              </div>
            </div>
            <div>
              <h3 class="font-oswald font-bold text-display-7 text-white mb-2">
                Atención Personalizada
              </h3>
              <p class="text-display-5 text-gray-400">
                Planes adaptados a tus objetivos, nivel de entrenamiento y necesidades específicas
              </p>
            </div>
          </div>
          <div class="flex gap-4 p-6 rounded-lg bg-zinc-800/30 border border-zinc-800 hover:border-yellow-400/30 transition-all duration-300">
            <div class="flex-shrink-0">
              <div class="w-12 h-12 bg-yellow-400 rounded-full flex items-center justify-center">
                <span class="text-2xl">💪</span>
              </div>
            </div>
            <div>
              <h3 class="font-oswald font-bold text-display-7 text-white mb-2">
                Resultados Garantizados
              </h3>
              <p class="text-display-5 text-gray-400">
                Seguimiento continuo para asegurar que alcances tus metas de forma efectiva
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-black text-white animate-section">
      <div class="max-w-4xl mx-auto px-4 md:px-10 text-center">
        <h2 class="text-display-10 md:text-display-11 font-oswald font-bold mb-6">
          Agenda una Consulta Personalizada
        </h2>
        <p class="text-display-6 md:text-display-8 text-gray-300 mb-8">
          Nuestros expertos están listos para ayudarte a crear el plan perfecto para tus objetivos
        </p>
        <a
          href="/contact"
          class="inline-block bg-yellow-400 text-black text-display-7 md:text-display-9 font-oswald font-mid
            px-8 py-4 rounded-radius-sm
            transition-all duration-300 ease-out
            hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
            focus:outline-none focus:ring-2 focus:ring-yellow-300"
        >
          Contactar Ahora
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    import { gsap } from 'gsap';
    import { initScrollAnimations } from '../utils/animations';

    class ExpertsPageAnimations {
      constructor() {
        this.init();
      }

      init() {
        if (typeof window === 'undefined') return;

        const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        if (prefersReducedMotion) {
          // Show all elements immediately if user prefers reduced motion
          gsap.set('.hero-content, .hero-image', { opacity: 1 });
          return;
        }

        this.animateHero();
        this.animateCounters();
        this.animateFloatingBadge();
      }

      animateHero() {
        const heroContent = document.querySelector('.hero-content');
        const heroImage = document.querySelector('.hero-image');
        const heroTitle = document.querySelector('.hero-title');
        const heroButtons = document.querySelectorAll('.hero-button');

        if (!heroContent || !heroImage) return;

        // Create timeline for hero entrance
        const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });

        // Animate content from left
        tl.fromTo(heroContent,
          { opacity: 0, x: -60 },
          { opacity: 1, x: 0, duration: 1 }
        );

        // Animate image from right
        tl.fromTo(heroImage,
          { opacity: 0, x: 60 },
          { opacity: 1, x: 0, duration: 1 },
          '-=0.7' // Overlap with previous animation
        );

        // Animate title with scale effect
        if (heroTitle) {
          tl.fromTo(heroTitle,
            { opacity: 0, y: 30, scale: 0.95 },
            { opacity: 1, y: 0, scale: 1, duration: 0.8, ease: 'back.out(1.5)' },
            '-=0.8'
          );
        }

        // Animate buttons with bounce
        if (heroButtons.length > 0) {
          tl.fromTo(heroButtons,
            { opacity: 0, y: 20, scale: 0.9 },
            {
              opacity: 1,
              y: 0,
              scale: 1,
              duration: 0.6,
              stagger: 0.12,
              ease: 'back.out(1.7)',
            },
            '-=0.4'
          );
        }
      }

      animateCounters() {
        const counters = document.querySelectorAll('.counter');

        counters.forEach((counter) => {
          const target = parseInt(counter.getAttribute('data-target') || '0');
          const obj = { value: 0 };

          gsap.to(obj, {
            value: target,
            duration: 2,
            delay: 1.2,
            ease: 'power2.out',
            onUpdate: () => {
              counter.textContent = Math.round(obj.value).toString();
            },
          });
        });
      }

      animateFloatingBadge() {
        const badge = document.querySelector('.floating-badge');
        if (!badge) return;

        // Subtle floating animation
        gsap.to(badge, {
          y: -10,
          duration: 2,
          repeat: -1,
          yoyo: true,
          ease: 'sine.inOut',
        });
      }
    }

    // Initialize animations when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        new ExpertsPageAnimations();
        initScrollAnimations();
      });
    } else {
      new ExpertsPageAnimations();
      initScrollAnimations();
    }
  </script>

  <style>
    .hero-content,
    .hero-image {
      will-change: opacity, transform;
    }

    .counter {
      display: inline-block;
      will-change: contents;
    }

    .floating-badge {
      will-change: transform;
    }

    /* Smooth gradient animation on hover for trainer cards */
    @keyframes gradient-shift {
      0%, 100% {
        background-position: 0% 50%;
      }
      50% {
        background-position: 100% 50%;
      }
    }
  </style>
</BaseLayout>
