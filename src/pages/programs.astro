---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/header/Header.astro';
import Footer from '../components/footer/Footer.astro';
import { Image } from "astro:assets";
import Creatina from "../assets/images/creatine.png";
import Proteina from "../assets/images/protein.png";
import Preentreno from "../assets/images/pre.png";
import Bcaa from "../assets/images/bcaa.png";
import ImageHeroProducts from "../assets/images/protein-SectionHero-Products.png";
import '../styles/global.css';
import '../styles/fonts.css';

const programs = await getCollection('programs');
const sortedPrograms = programs.sort((a, b) => a.data.order - b.data.order);

const imageMap: Record<string, any> = {
  "/src/assets/images/protein.png": Proteina,
  "/src/assets/images/creatine.png": Creatina,
  "/src/assets/images/pre.png": Preentreno,
  "/src/assets/images/bcaa.png": Bcaa,
};
---

<BaseLayout
  title="Productos - Iron Supplements"
  description="Explora nuestra línea completa de suplementos deportivos premium. Proteína, creatina, pre-entreno, BCAAs y más."
>
  <Header />

  <main class="bg-black">
    <!-- Hero Section (matching Home Hero structure) -->
    <section class="bg-black text-white xl:p-0 md:pb-[400px] pb-[150px] overflow-hidden rounded-b-radius-xl pt-20 md:pt-24 relative">
      <div class="xl:flex xl:flex-row justify-center items-center p-0 md:p-[100px]">
        <Image
          alt="Iron Supplements - Productos Premium"
          src={ImageHeroProducts}
          class="xl:max-h-[48vh] 2xl:max-h-[28vh] w-auto xl:opacity-100 opacity-40"
          loading="eager"
        />
        <div class="flex flex-col items-center xl:max-w-[50%] gap-6 md:gap-10 xl:mt-0 mt-[-500px] md:mt-[-700px] relative z-40 px-4">
          <h1 class="hero-title lg:text-[90px] lg:max-w-[50%] xl:max-w-[100%] text-display-mobile-12 md:text-display-10 leading-106 text-center font-oswald font-bold">
            NUESTROS PRODUCTOS
          </h1>
          <p class="text-display-6 md:text-display-8 text-gray-300 text-center max-w-2xl px-4">
            Suplementos de la más alta calidad, respaldados por la ciencia y diseñados para maximizar tu rendimiento
          </p>

          <!-- CTA Buttons -->
          <div class="flex flex-col sm:flex-row gap-4 sm:gap-6 w-full sm:w-auto px-4 max-w-xl">
            <!-- Primary CTA -->
            <a
              href="#productos"
              class="hero-button
                inline-flex items-center justify-center
                bg-yellow-400 text-black
                px-6 py-3 sm:px-7 sm:py-3.5
                rounded-lg
                font-oswald font-semibold text-base sm:text-lg
                whitespace-nowrap
                transition-all duration-300 ease-out
                hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
                focus:outline-none focus:ring-2 focus:ring-yellow-300 focus:ring-offset-2 focus:ring-offset-black
                text-center
                min-h-[48px] sm:min-h-[52px]"
            >
              Ver Catálogo
            </a>

            <!-- Secondary CTA -->
            <a
              href="/contact"
              class="hero-button
                inline-flex items-center justify-center
                border-2 border-yellow-400 text-yellow-400
                px-6 py-3 sm:px-7 sm:py-3.5
                rounded-lg
                font-oswald font-semibold text-base sm:text-lg
                whitespace-nowrap
                transition-all duration-300 ease-out
                hover:bg-yellow-400 hover:text-black hover:shadow-lg hover:scale-[1.02]
                focus:outline-none focus:ring-2 focus:ring-yellow-300 focus:ring-offset-2 focus:ring-offset-black
                text-center
                min-h-[48px] sm:min-h-[52px]"
            >
              Contáctanos
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Products Grid -->
    <section id="productos" class="py-sections-xs bg-neutral-900">
      <div class="max-w-[1120px] mx-auto px-4 md:px-10">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12 animate-cards">
          {sortedPrograms.map((program, index) => (
            <div
              class="product-accordion bg-zinc-800/50 backdrop-blur-sm rounded-radius-lg overflow-hidden
                border border-zinc-700 hover:border-yellow-400/30
                transition-all duration-300 cursor-pointer group"
              data-product-index={index}
            >
              <!-- Accordion Header (Always Visible) -->
              <button
                class="accordion-trigger w-full text-left focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:ring-inset"
                aria-expanded="false"
                aria-controls={`product-content-${index}`}
              >
                <div class="bg-yellow-400 p-6 md:p-8 flex items-center justify-center min-h-[200px] md:min-h-[250px] relative">
                  <Image
                    alt={program.data.title}
                    src={imageMap[program.data.image]}
                    class="h-[180px] md:h-[220px] w-auto transform group-hover:scale-105 transition-transform duration-500"
                  />

                  <!-- Expand/Collapse Icon -->
                  <div class="absolute bottom-4 right-4 bg-black/80 rounded-full p-2 transition-all duration-300 group-hover:bg-black">
                    <svg class="accordion-icon w-6 h-6 text-yellow-400 transition-transform duration-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M19 9l-7 7-7-7" />
                    </svg>
                  </div>
                </div>

                <div class="p-6 md:p-8">
                  <div class="flex items-center justify-between gap-3">
                    <div class="flex items-center gap-3 flex-1">
                      <span class="text-3xl md:text-4xl">{program.data.icon}</span>
                      <h2 class="text-display-8 md:text-display-9 font-oswald font-bold text-white">
                        {program.data.title}
                      </h2>
                    </div>
                  </div>
                </div>
              </button>

              <!-- Accordion Content (Expandable) -->
              <div
                id={`product-content-${index}`}
                class="accordion-content overflow-hidden"
                style="height: 0; opacity: 0;"
              >
                <div class="accordion-inner px-6 md:px-8 pb-6 md:pb-8">
                  <p class="text-display-5 md:text-display-6 text-gray-300 mb-6 leading-relaxed">
                    {program.data.description}
                  </p>

                  <div class="space-y-3 mb-6">
                    <h3 class="font-oswald font-semibold text-display-6 md:text-display-7 text-white flex items-center gap-2">
                      <svg class="w-5 h-5 text-yellow-400" fill="currentColor" viewBox="0 0 20 20">
                        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                      </svg>
                      Beneficios Clave
                    </h3>
                    <ul class="space-y-2 pl-1">
                      {program.data.features.map((feature: string) => (
                        <li class="flex items-start gap-2 text-display-4 md:text-display-5 text-gray-400">
                          <svg class="w-4 h-4 md:w-5 md:h-5 text-yellow-400 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                          </svg>
                          <span>{feature}</span>
                        </li>
                      ))}
                    </ul>
                  </div>

                  <div class="pt-4 border-t border-zinc-700">
                    <a
                      href="/contact"
                      class="inline-flex items-center justify-center w-full sm:w-auto
                        bg-yellow-400 text-black text-display-5 md:text-display-6 font-oswald font-semibold
                        px-6 py-3 rounded-radius-sm
                        transition-all duration-300 ease-out
                        hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
                        border-2 border-transparent focus:outline-none focus:ring-2 focus:ring-yellow-300"
                      onclick="event.stopPropagation()"
                    >
                      <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                      </svg>
                      Consultar Disponibilidad
                    </a>
                  </div>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA Section -->
    <section class="py-20 bg-zinc-900 border-y border-zinc-800">
      <div class="max-w-4xl mx-auto px-4 md:px-10 text-center">
        <h2 class="text-display-10 md:text-display-11 font-oswald font-bold mb-6 text-white">
          ¿No estás seguro cuál producto necesitas?
        </h2>
        <p class="text-display-6 text-gray-400 mb-8">
          Nuestro equipo de expertos está listo para ayudarte a elegir el suplemento perfecto para tus objetivos
        </p>
        <a
          href="/contact"
          class="inline-block bg-yellow-400 text-black text-display-7 md:text-display-9 font-oswald font-mid
            px-8 py-4 rounded-radius-sm
            transition-all duration-300 ease-out
            hover:bg-yellow-300 hover:shadow-lg hover:scale-[1.02]
            border-2 border-transparent focus:outline-none focus:ring-2 focus:ring-yellow-300 focus:ring-offset-2 focus:ring-offset-zinc-900"
        >
          Hablar con un Experto
        </a>
      </div>
    </section>
  </main>

  <Footer />

  <script>
    import { gsap } from 'gsap';
    import { initScrollAnimations } from '../utils/animations';

    class ProductAccordion {
      private accordions: NodeListOf<Element>;

      constructor() {
        this.accordions = document.querySelectorAll('.product-accordion');
        this.init();
      }

      init() {
        this.accordions.forEach((accordion) => {
          const trigger = accordion.querySelector('.accordion-trigger') as HTMLButtonElement;
          const content = accordion.querySelector('.accordion-content') as HTMLElement;
          const icon = accordion.querySelector('.accordion-icon') as HTMLElement;

          if (!trigger || !content || !icon) return;

          trigger.addEventListener('click', () => {
            const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

            if (isExpanded) {
              this.collapse(trigger, content, icon);
            } else {
              // Collapse all other accordions first
              this.collapseAll();
              this.expand(trigger, content, icon);
            }
          });
        });
      }

      expand(trigger: HTMLButtonElement, content: HTMLElement, icon: HTMLElement) {
        const inner = content.querySelector('.accordion-inner') as HTMLElement;
        if (!inner) return;

        trigger.setAttribute('aria-expanded', 'true');

        // Get the natural height
        const contentHeight = inner.scrollHeight;

        // Animate expansion
        gsap.to(content, {
          height: contentHeight,
          opacity: 1,
          duration: 0.6,
          ease: 'power3.out',
        });

        // Rotate icon
        gsap.to(icon, {
          rotation: 180,
          duration: 0.5,
          ease: 'power2.out',
        });

        // Add active state to card
        const card = trigger.closest('.product-accordion');
        if (card) {
          gsap.to(card, {
            borderColor: 'rgba(250, 204, 21, 0.5)', // yellow-400 with opacity
            duration: 0.3,
          });
        }
      }

      collapse(trigger: HTMLButtonElement, content: HTMLElement, icon: HTMLElement) {
        trigger.setAttribute('aria-expanded', 'false');

        // Animate collapse
        gsap.to(content, {
          height: 0,
          opacity: 0,
          duration: 0.5,
          ease: 'power3.in',
        });

        // Rotate icon back
        gsap.to(icon, {
          rotation: 0,
          duration: 0.4,
          ease: 'power2.in',
        });

        // Remove active state from card
        const card = trigger.closest('.product-accordion');
        if (card) {
          gsap.to(card, {
            borderColor: 'rgb(63, 63, 70)', // zinc-700
            duration: 0.3,
          });
        }
      }

      collapseAll() {
        this.accordions.forEach((accordion) => {
          const trigger = accordion.querySelector('.accordion-trigger') as HTMLButtonElement;
          const content = accordion.querySelector('.accordion-content') as HTMLElement;
          const icon = accordion.querySelector('.accordion-icon') as HTMLElement;

          if (trigger?.getAttribute('aria-expanded') === 'true') {
            this.collapse(trigger, content, icon);
          }
        });
      }
    }

    // Initialize when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', () => {
        initScrollAnimations();
        new ProductAccordion();
      });
    } else {
      initScrollAnimations();
      new ProductAccordion();
    }
  </script>

  <style>
    .product-accordion {
      will-change: border-color;
    }

    .accordion-content {
      will-change: height, opacity;
    }

    .accordion-icon {
      will-change: transform;
    }

    /* Smooth hover state */
    .product-accordion:hover .accordion-icon {
      transform: translateY(2px);
    }

    /* Active state styling */
    .product-accordion[aria-expanded="true"] {
      box-shadow: 0 20px 25px -5px rgb(0 0 0 / 0.3), 0 8px 10px -6px rgb(0 0 0 / 0.3);
    }
  </style>
</BaseLayout>
